{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "BossGreet",
  "version": "2.0.0",
  "description": "BOSS 直聘智能招呼语生成器 — MiMo AI 驱动的简历分析和 JD 匹配",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "BossGreet"
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "alarms"],
  "host_permissions": ["*://*.zhipin.com/*", "https://api.xiaomimimo.com/*", "https://token-plan-sgp.xiaomimimo.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.zhipin.com/web/geek/chat*"],
      "js": ["src/content/ws-probe.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.zhipin.com/web/geek/jobs*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/content/jd-extractor.js",
        "src/shared/error-logger.js",
        "src/content/job-collector.js",
        "src/content/job-sender.js",
        "src/content/job-clicker.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/web/geek/chat*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/shared/error-logger.js",
        "src/content/chat-monitor.js",
        "src/content/job-sender.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/job_detail/*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/shared/error-logger.js",
        "src/content/job-sender.js",
        "src/content/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/db/*", "src/utils/*", "libs/*"],
      "matches": ["*://*.zhipin.com/*"]
    }
  ]
}
