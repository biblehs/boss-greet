{
  "manifest_version": 3,
  "name": "BossGreet",
  "version": "1.2.0",
  "description": "BOSS Zhipin personalized greeting generator — matches each job description with your resume to craft tailored outreach messages",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "BossGreet"
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "alarms"],
  "host_permissions": [
    "*://*.zhipin.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.zhipin.com/web/geek/jobs*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/content/jd-extractor.js",
        "src/content/job-collector.js",
        "src/content/job-sender.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/web/geek/chat*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/content/jd-extractor.js",
        "src/content/job-sender.js",
        "src/content/chat-monitor.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.zhipin.com/job_detail/*"],
      "js": [
        "src/content/selectors.js",
        "src/content/salary-decoder.js",
        "src/content/jd-extractor.js",
        "src/content/job-sender.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/*", "src/utils/*"],
      "matches": ["*://*.zhipin.com/*"]
    }
  ]
}
